# AdminBackend – all values from .env (no fallbacks)
NODE_ENV=development
PORT=8002
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=candidates_db
AUTH_DB_NAME=auth_db
DB_POOL_SIZE=10

# Service
INTERNAL_SERVICE_TOKEN=your_internal_token
SERVICE_NAME=admin-backend
# Must match SuperadminBackend (auth service) – AdminFrontend login issues token from 8001; AdminBackend verifies it
JWT_SECRET=your_jwt_secret

# Other services (when AdminBackend calls them)
# Auth (SuperadminBackend, port 8001): proxy GET /auth/users/:id -> GET {AUTH_SERVICE_URL}/users/:id
AUTH_SERVICE_URL=http://localhost:8001
# Streaming (port 9002): resume score POST /resume-ats/calculate-score + schedule-interview POST /schedule-interview (ref: backend_ai-main)
STREAMING_SERVICE_URL=http://localhost:9002
AI_SERVICE_URL=http://localhost:9002
CANDIDATE_SERVICE_URL=http://localhost:8003

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003,http://localhost:5173,http://127.0.0.1:4000,http://127.0.0.1:4001,http://127.0.0.1:4002,http://127.0.0.1:4003

# GCP Cloud Storage (live bucket) – same path: bucket/folderId/Resume and folderId/JD
# GCS_BUCKET=qwikhire-prod-storage
# STORAGE_FOLDER_ID=6464-0160-2190-198-79266
# Optional: service account key path (else uses Application Default Credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Optional
SWAGGER_SERVER_URL=http://localhost:8002
FRONTEND_URL=http://localhost:4001
CANDIDATE_LINK_BASE_URL=http://localhost:4002
TENANT_DB=
